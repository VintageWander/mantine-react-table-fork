{
	"name": "mantine-react-table",
	"version": "0.0.1",
	"license": "MIT",
	"description": "Mantine + Tanstack Table",
	"author": "Wander Watterson",
	"keywords": [
		"react-table",
		"mantine",
		"tanstack table",
		"data table",
		"data grid"
	],
	"sideEffects": [
		"*.css"
	],
	"main": "dist/index.cjs",
	"module": "dist/index.esm.mjs",
	"types": "dist/index.esm.d.mts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.esm.d.mts",
				"default": "./dist/index.esm.mjs"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		},
		"./package.json": "./package.json",
		"./locales/*": "./locales/*",
		"./styles.css": "./styles.css"
	},
	"files": [
		"dist",
		"locales",
		"styles.css",
		"src"
	],
	"engines": {
		"node": ">=18"
	},
	"scripts": {
		"build": "bun run build-lib && bun run build-locales",
		"build-lib": "rm -rf dist && rollup -c rollup.config.mjs",
		"build-locales": "node build-locales.mjs",
		"dev": "rollup -c rollup.config.mjs --watch",
		"check": "biome check --write",
		"format": "biome format --write",
		"lint": "biome check"
	},
	"dependencies": {
		"@tanstack/match-sorter-utils": "^8.19.4",
		"@tanstack/react-table": "^8.21.3",
		"@tanstack/react-virtual": "^3.13.12"
	},
	"peerDependencies": {
		"@mantine/core": "^8",
		"@mantine/dates": "^8",
		"@mantine/hooks": "^8",
		"@tabler/icons-react": ">=2.23.0",
		"clsx": ">=2",
		"dayjs": ">=1.11",
		"react": ">=18",
		"react-dom": ">=18"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.16",
		"@mantine/core": "^8.0.0",
		"@mantine/dates": "^8.0.0",
		"@mantine/hooks": "^8.0.0",
		"@rollup/plugin-typescript": "^12.3.0",
		"@tabler/icons-react": "^3.44.0",
		"@types/node": "^25.9.1",
		"@types/react": "^19.2.16",
		"@types/react-dom": "^19.2.3",
		"clsx": "^2.1.1",
		"dayjs": "^1.11.13",
		"postcss": "^8.4.47",
		"postcss-preset-mantine": "^1.17.0",
		"postcss-simple-vars": "^7.0.1",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"rollup": "^4.61.1",
		"rollup-plugin-copy": "^3.5.0",
		"rollup-plugin-delete": "^3.0.2",
		"rollup-plugin-dts": "^6.1.1",
		"rollup-plugin-postcss": "^4.0.2",
		"tslib": "^2.7.0",
		"typescript": "^6.0.3",
		"typescript-plugin-css-modules": "^5.1.0"
	}
}
